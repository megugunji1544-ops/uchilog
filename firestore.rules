rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)).data.active == true;
    }

    match /allowedUsers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /events/{eventId} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAllowedUser()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAllowedUser();
    }

    match /settings/{documentId} {
      allow read, write: if isAllowedUser();
    }


    match /notificationTokens/{uid}/tokens/{tokenId} {
      allow read: if isAllowedUser() && request.auth.uid == uid;
      allow create, update: if isAllowedUser()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAllowedUser() && request.auth.uid == uid;
    }

    match /migrations/{uid} {
      allow read: if isAllowedUser() && request.auth.uid == uid;
      allow create, update: if isAllowedUser()
        && request.auth.uid == uid
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
